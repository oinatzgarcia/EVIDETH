# ─────────────────────────────────────────
# EVIDETH - Environment Variables Template
# Copia este archivo como .env y rellena
# ─────────────────────────────────────────

# ── APP ──────────────────────────────────
APP_NAME=EVIDETH
APP_ENV=development          # development | production
APP_PORT=8000
DEBUG=True
SECRET_KEY=your-super-secret-key-here-change-in-production

# ── DATABASE ─────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/evideth_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=evideth_db
DB_USER=postgres
DB_PASSWORD=your-db-password

# ── JWT AUTH ─────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── AZURE KEY VAULT ───────────────────────
AZURE_KEY_VAULT_URL=https://your-vault-name.vault.azure.net/
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret
AZURE_TENANT_ID=your-azure-tenant-id

# ── AZURE BLOB STORAGE ────────────────────
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
AZURE_STORAGE_CONTAINER_NAME=evideth-videos

# ── CRYPTOGRAPHY ──────────────────────────
ECDSA_KEY_NAME=evideth-signing-key       # Nombre de la clave en Azure Key Vault
HASH_ALGORITHM=SHA-256
SEGMENT_DURATION_SECONDS=30

# ── VIDEO PROCESSING ──────────────────────
MAX_VIDEO_SIZE_MB=500
UPLOAD_TEMP_DIR=./uploads/temp
SEGMENTS_DIR=./uploads/segments
SUPPORTED_FORMATS=mp4,avi,mov,mkv

# ── CAMERA SIMULATOR ──────────────────────
CAMERA_API_KEY=your-camera-api-key
CAMERA_STREAM_URL=rtsp://localhost:8554/stream
CAMERA_FPS=30

# ── CORS ─────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_ALLOW_CREDENTIALS=True

# ── LOGGING ──────────────────────────────
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
LOG_FILE=./logs/evideth.log
