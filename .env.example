# =============================================================================
# EVIDETH — Environment Variables Template
# Copia este fichero como .env y rellena los valores reales.
# NUNCA subas el .env real al repositorio.
# =============================================================================


# ── APP ────────────────────────────────────────────────────────────────────────
APP_NAME=EVIDETH
APP_ENV=development          # development | production | test
APP_PORT=8000
DEBUG=True

# Clave aleatoria de al menos 32 caracteres. Genera con:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-use-a-random-32-char-secret


# ── DATABASE ───────────────────────────────────────────────────────────────
# URL completa usada por SQLAlchemy / Alembic
DATABASE_URL=postgresql://evideth_user:evideth_pass@localhost:5432/evideth_db

# Variables individuales usadas por docker-compose para crear el contenedor PG
DB_HOST=localhost
DB_PORT=5432
DB_NAME=evideth_db
DB_USER=evideth_user
DB_PASSWORD=evideth_pass


# ── JWT AUTH ───────────────────────────────────────────────────────────────
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-use-a-different-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7


# ── AZURE KEY VAULT ────────────────────────────────────────────────────────
# Portal Azure → Key Vault → Overview (URL) + App Registration (IDs)
AZURE_KEY_VAULT_URL=https://your-vault-name.vault.azure.net/
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=your-azure-client-secret
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx


# ── AZURE BLOB STORAGE ───────────────────────────────────────────────────
# Portal Azure → Storage Account → Access keys → Connection string
# Dejar vacío para ejecutar en local sin Azure (Blob Storage se desactiva).
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your_account;AccountKey=your_key;EndpointSuffix=core.windows.net
AZURE_BLOB_CONTAINER=evideth-videos


# ── CRYPTOGRAPHY ────────────────────────────────────────────────────────────
ECDSA_KEY_NAME=evideth-signing-key   # Nombre de la clave ECDSA P-256 en Key Vault
HASH_ALGORITHM=SHA-256
SEGMENT_DURATION_SECONDS=30


# ── VIDEO PROCESSING ──────────────────────────────────────────────────────
MAX_VIDEO_SIZE_MB=2048               # 2 GB máximo (igual que MAX_UPLOAD_BYTES)
UPLOAD_TEMP_DIR=/tmp
SEGMENTS_DIR=/tmp/segments
SUPPORTED_FORMATS=mp4,avi,mov,mkv


# ── CAMERA SIMULATOR ──────────────────────────────────────────────────────
# API Key que el simulador usa para autenticarse contra el backend
CAMERA_API_KEY=your-camera-api-key-here
CAMERA_ID=CAM-01
CAMERA_STREAM_URL=rtsp://localhost:8554/stream
CAMERA_FPS=30
# URL del backend que recibe los segmentos (dentro de Docker: nombre del servicio)
BACKEND_URL=http://backend:8000


# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_ALLOW_CREDENTIALS=True


# ── LOGGING ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR
LOG_FILE=./logs/evideth.log
