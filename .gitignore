# ─────────────────────────────────────────
# EVIDETH - Git Ignore
# ─────────────────────────────────────────

# ── SECRETS (NUNCA subir) ─────────────────
.env
*.key
*.pem
*.p12
*.pfx
azure_credentials.json
service_account.json

# ── PYTHON ───────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
eggs/
.eggs/
*.egg-info/
*.egg
MANIFEST

# ── ENTORNOS VIRTUALES ────────────────────
venv/
env/
ENV/
.venv/
.env/

# ── VIDEOS Y UPLOADS (archivos pesados) ───
uploads/
*.mp4
*.avi
*.mov
*.mkv
*.m4v
*.flv
*.wmv
*.webm

# ── DATABASE ─────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── LOGS ─────────────────────────────────
logs/
*.log
*.log.*

# ── TESTING Y COVERAGE ───────────────────
.coverage
.pytest_cache/
htmlcov/
.tox/
coverage.xml
*.cover

# ── IDEs ─────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
*~
.project
.classpath

# ── OS ───────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# ── DOCKER ───────────────────────────────
.dockerignore

# ── COMPILADOS ───────────────────────────
*.pyc
*.pyo

# ── TEMP ─────────────────────────────────
tmp/
temp/
.tmp/
*.tmp
*.bak
*.cache
