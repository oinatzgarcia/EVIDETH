# ================================================================
# EVIDETH Camera Simulator — Variables de entorno
# Copiar este fichero como .env y rellenar los valores reales.
# NUNCA subir el .env al repositorio (ya está en .gitignore).
# ================================================================

# URL del backend EVIDETH (sin barra final)
# Desarrollo local:  http://localhost:8000/api/v1
# Producción Azure:  https://tu-app.azurewebsites.net/api/v1
API_URL=https://tu-app.azurewebsites.net/api/v1

# API Key de esta cámara (obtenida al registrar la cámara en el panel de admin)
CAMERA_API_KEY=your-camera-api-key-here

# Identificador único de la cámara (debe coincidir con el registrado en el servidor)
CAMERA_ID=CAM-SIM-01

# ── Vídeo ───────────────────────────────────────────────
# Duración de cada segmento en segundos (máximo 60 por política del servidor)
SEGMENT_DURATION=60

# Frames por segundo del vídeo sintético
FPS=25

# Resolución del vídeo (ancho x alto en píxeles)
WIDTH=1280
HEIGHT=720

# ── Criptografía ─────────────────────────────────────────────
# 'local'  → clave PEM generada automáticamente en PRIVATE_KEY_FILE
# 'azure'  → firma mediante Azure Key Vault (requiere AZURE_VAULT_URL y AZURE_KEY_NAME)
SIGNING_MODE=local

# Ruta de la clave privada ECDSA P-256 (solo SIGNING_MODE=local)
# Se genera automáticamente en el primer arranque si no existe.
PRIVATE_KEY_FILE=/keys/camera_private.pem

# Azure Key Vault (solo necesario si SIGNING_MODE=azure)
# AZURE_VAULT_URL=https://evideth-kv.vault.azure.net/
# AZURE_KEY_NAME=camera-signing-key

# ── Comportamiento del daemon ───────────────────────────────────
# Segundos entre heartbeats (debe ser <= CAMERA_ONLINE_THRESHOLD_SECONDS del servidor)
HEARTBEAT_INTERVAL=30

# Número de reintentos por petición fallida
MAX_RETRIES=3

# Segundos de espera base entre reintentos (se multiplica por el número de intento)
RETRY_DELAY=5

# ── Demo / Testing ─────────────────────────────────────────────
# Poner en 'true' para corromper 1 de cada 3 segmentos y demostrar
# que el sistema detecta la manipulación en la verificación forense.
TAMPER_MODE=false
